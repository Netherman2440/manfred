API_V1_STR=/api/v1
PROJECT_NAME=Manfred API
VERSION=0.0.0-dev
DESCRIPTION=Agent API
API_HOST=127.0.0.1
API_PORT=3000
API_RELOAD=false
API_CORS_ORIGINS=http://localhost:3001
API_CORS_ALLOW_LOCALHOST=true
DATABASE_URL=sqlite:///./manfred.db

DEFAULT_AGENT=
WORKSPACE_PATH=.agent_data
FS_ROOT=
FS_ROOTS=.agent_data/agents,.agent_data/shared,.agent_data/skills,.agent_data/workflows,.agent_data/workspaces
FS_EXCLUDE=
MAX_FILE_SIZE=524288
MCP_CONFIG_PATH=.mcp.json
MCP_TOOL_TIMEOUT_MS=30000
MAX_DELEGATION_DEPTH=8

OPEN_ROUTER_URL=https://openrouter.ai/api/v1
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_LLM_MODEL=openai/gpt-4o-mini
OPEN_ROUTER_SLM_MODEL=openai/gpt-4o-mini
DEFAULT_USER_ID=default-user
DEFAULT_USER_NAME=Default User

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development
AI_DEVS_API_KEY=
AI_DEVS_HUB_URL=https://hub.ag3nts.org
